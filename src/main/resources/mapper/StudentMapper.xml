<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.student.mapper.StudentMapper">

    <resultMap id="StudentMap" type="cn.yanque.models.student.pojo.entity.StudentEntity">
        <id property="id" column="id"/>
        <result property="studentNo" column="student_no"/>
        <result property="studentName" column="student_name"/>
        <result property="studentPhone" column="student_phone"/>
        <result property="password" column="password"/>
        <result property="education" column="education"/>
        <result property="gradeYear" column="grade_year"/>
        <result property="school" column="school"/>
        <result property="major" column="major"/>
        <result property="teachingMode" column="teaching_mode"/>
        <result property="classId" column="class_id"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, student_no, student_name, student_phone, password, education, grade_year, school, major, teaching_mode, class_id, status, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into student (
            student_no,
            student_name,
            student_phone,
            password,
            education,
            grade_year,
            school,
            major,
            teaching_mode,
            class_id,
            status,
            created_at,
            updated_at
        )
        values (
            #{studentNo},
            #{studentName},
            #{studentPhone},
            #{password},
            #{education},
            #{gradeYear},
            #{school},
            #{major},
            #{teachingMode},
            #{classId},
            #{status},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <select id="selectById" resultMap="StudentMap">
        select <include refid="BaseColumns"/>
        from student
        where id = #{id}
    </select>

    <select id="selectByPhone" resultMap="StudentMap">
        select <include refid="BaseColumns"/>
        from student
        where student_phone = #{studentPhone}
        limit 1
    </select>

    <select id="selectPage" resultMap="StudentMap">
        select <include refid="BaseColumns"/>
        from student
        <where>
            <if test="studentName != null and studentName != ''">
                and student_name like concat('%', #{studentName}, '%')
            </if>
            <if test="studentPhone != null and studentPhone != ''">
                and student_phone like concat('%', #{studentPhone}, '%')
            </if>
            <if test="education != null and education != ''">
                and education = #{education}
            </if>
            <if test="school != null and school != ''">
                and school like concat('%', #{school}, '%')
            </if>
            <if test="teachingMode != null and teachingMode != ''">
                and teaching_mode = #{teachingMode}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by id desc
    </select>
</mapper>
