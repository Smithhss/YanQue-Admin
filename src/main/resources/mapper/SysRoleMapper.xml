<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.users.mapper.SysRoleMapper">

    <resultMap id="SysRoleMap" type="cn.yanque.models.users.pojo.entity.SysRoleEntity">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, role_code, role_name, description, status, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into sys_role (role_code, role_name, description, status, created_at, updated_at)
        values (#{roleCode}, #{roleName}, #{description}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateById">
        update sys_role
        set role_code = #{roleCode},
            role_name = #{roleName},
            description = #{description},
            status = #{status},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <select id="selectById" resultMap="SysRoleMap">
        select <include refid="BaseColumns"/>
        from sys_role
        where id = #{id}
    </select>

    <select id="selectByRoleCode" resultMap="SysRoleMap">
        select <include refid="BaseColumns"/>
        from sys_role
        where role_code = #{roleCode}
    </select>

    <select id="selectPage" resultMap="SysRoleMap">
        select <include refid="BaseColumns"/>
        from sys_role
        <where>
            <if test="keyword != null and keyword != ''">
                and (role_code like concat('%', #{keyword}, '%')
                or role_name like concat('%', #{keyword}, '%'))
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
        </where>
        order by id desc
    </select>

    <delete id="deleteById">
        delete from sys_role where id = #{id}
    </delete>

    <delete id="deleteRolePermissions">
        delete from sys_role_permission where role_id = #{roleId}
    </delete>

    <delete id="deleteUserRoles">
        delete from sys_user_role where role_id = #{roleId}
    </delete>

    <insert id="insertRolePermissions">
        insert into sys_role_permission (role_id, permission_id, created_at)
        values
        <foreach collection="permissionIds" item="permissionId" separator=",">
            (#{roleId}, #{permissionId}, now())
        </foreach>
    </insert>

    <select id="selectPermissionIdsByRoleId" resultType="java.lang.Long">
        select permission_id
        from sys_role_permission
        where role_id in
        <foreach collection="roleIds" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
        order by permission_id asc
    </select>


    <select id="selectList" resultMap="SysRoleMap">
        select <include refid="BaseColumns"/>
        from sys_role
        <where>
            <if test="ids != null and ids.size > 0">
                and id in
                <foreach collection="ids" item="item" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>
        </where>
    </select>
</mapper>
