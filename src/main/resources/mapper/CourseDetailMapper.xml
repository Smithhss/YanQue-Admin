<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.teaching.course.mapper.CourseDetailMapper">

    <resultMap id="CourseDetailMap" type="cn.yanque.models.teaching.course.pojo.entity.CourseDetailEntity">
        <id property="id" column="id"/>
        <result property="courseId" column="course_id"/>
        <result property="stageName" column="stage_name"/>
        <result property="dayNumber" column="day_number"/>
        <result property="classContent" column="class_content"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, course_id, stage_name, day_number, class_content, created_at, updated_at
    </sql>

    <!-- 新增课程详情时不手动写创建/更新时间，交给数据库默认值维护。 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into sys_course_detail (course_id, stage_name, day_number, class_content)
        values (#{courseId}, #{stageName}, #{dayNumber}, #{classContent})
    </insert>

    <update id="updateById">
        update sys_course_detail
        set stage_name = #{stageName},
            day_number = #{dayNumber},
            class_content = #{classContent}
        where id = #{id}
    </update>

    <select id="selectById" resultMap="CourseDetailMap">
        select <include refid="BaseColumns"/>
        from sys_course_detail
        where id = #{id}
    </select>

    <!-- 前端课程详情弹窗使用，按第几天排序，方便阶段单元格连续合并。 -->
    <select id="selectByCourseId" resultMap="CourseDetailMap">
        select <include refid="BaseColumns"/>
        from sys_course_detail
        where course_id = #{courseId}
        order by day_number asc, id asc
    </select>

    <delete id="deleteById">
        delete from sys_course_detail where id = #{id}
    </delete>

    <delete id="deleteByCourseId">
        delete from sys_course_detail where course_id = #{courseId}
    </delete>
</mapper>
