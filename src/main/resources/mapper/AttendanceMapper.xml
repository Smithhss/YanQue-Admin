<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.teaching.attendance.mapper.AttendanceMapper">

    <resultMap id="AttendanceMap" type="cn.yanque.models.teaching.attendance.pojo.entity.ClassAttendanceEntity">
        <id property="id" column="id"/>
        <result property="scheduleId" column="schedule_id"/>
        <result property="classId" column="class_id"/>
        <result property="studentId" column="student_id"/>
        <result property="scheduleDate" column="schedule_date"/>
        <result property="status" column="status"/>
        <result property="leaveReason" column="leave_reason"/>
        <result property="hourDeducted" column="hour_deducted"/>
        <result property="operatorId" column="operator_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="ScheduleMap" type="cn.yanque.models.teaching.schedule.pojo.entity.ClassScheduleEntity">
        <id property="id" column="id"/>
        <result property="classId" column="class_id"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="scheduleDate" column="schedule_date"/>
        <result property="courseDetailId" column="course_detail_id"/>
        <result property="courseContent" column="course_content"/>
        <result property="classType" column="class_type"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, schedule_id, class_id, student_id, schedule_date, status, leave_reason, hour_deducted, operator_id, created_at, updated_at
    </sql>

    <select id="selectScheduleById" resultMap="ScheduleMap">
        select id, class_id, teacher_id, schedule_date, course_detail_id, course_content, class_type, created_at, updated_at
        from sys_class_schedule
        where id = #{scheduleId}
    </select>

    <select id="selectByScheduleId" resultMap="AttendanceMap">
        select <include refid="BaseColumns"/>
        from class_attendance
        where schedule_id = #{scheduleId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into class_attendance
            (schedule_id, class_id, student_id, schedule_date, status, leave_reason, hour_deducted, operator_id, created_at, updated_at)
        values
            (#{scheduleId}, #{classId}, #{studentId}, #{scheduleDate}, #{status}, #{leaveReason}, #{hourDeducted}, #{operatorId}, now(), now())
    </insert>

    <update id="updateById">
        update class_attendance
        set status = #{status},
            leave_reason = #{leaveReason},
            hour_deducted = #{hourDeducted},
            operator_id = #{operatorId},
            updated_at = now()
        where id = #{id}
    </update>

    <select id="selectPage" resultMap="AttendanceMap">
        select <include refid="BaseColumns"/>
        from class_attendance
        <where>
            <if test="classId != null">
                and class_id = #{classId}
            </if>
            <if test="studentId != null">
                and student_id = #{studentId}
            </if>
            <if test="dateFrom != null and dateFrom != ''">
                and schedule_date &gt;= #{dateFrom}
            </if>
            <if test="dateTo != null and dateTo != ''">
                and schedule_date &lt;= #{dateTo}
            </if>
        </where>
        order by schedule_date desc, id desc
    </select>
</mapper>
