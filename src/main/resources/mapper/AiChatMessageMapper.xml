<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.ai.chat.mapper.AiChatMessageMapper">

    <resultMap id="AiChatMessageMap" type="cn.yanque.models.ai.chat.pojo.entity.AiChatMessageEntity">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="model" column="model"/>
        <result property="tokens" column="tokens"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, session_id, role, content, model, tokens, created_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into ai_chat_message (
            session_id,
            role,
            content,
            model,
            tokens,
            created_at
        )
        values (
            #{sessionId},
            #{role},
            #{content},
            #{model},
            #{tokens},
            #{createdAt}
        )
    </insert>

    <select id="selectBySessionId" resultMap="AiChatMessageMap">
        select <include refid="BaseColumns"/>
        from ai_chat_message
        where session_id = #{sessionId}
        order by created_at asc, id asc
    </select>

    <select id="selectLatestBySessionId" resultMap="AiChatMessageMap">
        select <include refid="BaseColumns"/>
        from (
            select <include refid="BaseColumns"/>
            from ai_chat_message
            where session_id = #{sessionId}
            order by created_at desc, id desc
            limit #{limit}
        ) t
        order by created_at asc, id asc
    </select>
</mapper>
