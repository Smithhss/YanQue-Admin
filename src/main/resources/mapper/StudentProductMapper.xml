<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.student.mapper.StudentProductMapper">

    <resultMap id="StudentProductMap" type="cn.yanque.models.student.pojo.entity.StudentProductEntity">
        <id property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="productId" column="product_id"/>
        <result property="sourceOrderNo" column="source_order_no"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into student_product (
            student_id,
            product_id,
            source_order_no,
            status,
            created_at,
            updated_at
        )
        values (
            #{studentId},
            #{productId},
            #{sourceOrderNo},
            #{status},
            #{createdAt},
            #{updatedAt}
        )
    </insert>

    <select id="selectByStudentIds" resultMap="StudentProductMap">
        select id, student_id, product_id, source_order_no, status, created_at, updated_at
        from student_product
        where student_id in
        <foreach collection="studentIds" item="studentId" open="(" separator="," close=")">
            #{studentId}
        </foreach>
        order by id asc
    </select>
</mapper>
