<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.yanque.models.dorm.mapper.DormRoomMapper">

    <resultMap id="DormRoomMap" type="cn.yanque.models.dorm.pojo.entity.DormRoomEntity">
        <id property="id" column="id"/>
        <result property="buildingId" column="building_id"/>
        <result property="roomNo" column="room_no"/>
        <result property="floor" column="floor"/>
        <result property="capacity" column="capacity"/>
        <result property="roomType" column="room_type"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, building_id, room_no, floor, capacity, room_type, status, created_at, updated_at
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into dorm_room (building_id, room_no, floor, capacity, room_type, status, created_at, updated_at)
        values (#{buildingId}, #{roomNo}, #{floor}, #{capacity}, #{roomType}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="updateById">
        update dorm_room
        set building_id = #{buildingId},
            room_no = #{roomNo},
            floor = #{floor},
            capacity = #{capacity},
            room_type = #{roomType},
            status = #{status},
            updated_at = #{updatedAt}
        where id = #{id}
    </update>

    <select id="selectById" resultMap="DormRoomMap">
        select <include refid="BaseColumns"/>
        from dorm_room
        where id = #{id}
    </select>

    <select id="selectByIds" resultMap="DormRoomMap">
        select <include refid="BaseColumns"/>
        from dorm_room
        where id in
        <foreach collection="ids" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>

    <select id="selectPage" resultMap="DormRoomMap">
        select <include refid="BaseColumns"/>
        from dorm_room
        <where>
            <if test="buildingId != null">
                and building_id = #{buildingId}
            </if>
            <if test="keyword != null and keyword != ''">
                and room_no like concat('%', #{keyword}, '%')
            </if>
        </where>
        order by id desc
    </select>

    <delete id="deleteById">
        delete from dorm_room where id = #{id}
    </delete>

    <select id="countByBuildingId" resultType="int">
        select count(*) from dorm_room where building_id = #{buildingId}
    </select>
</mapper>
